# ── Telegram ──────────────────────────────────────────────────────────────────
# Get your token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# ── Garmin Connect ─────────────────────────────────────────────────────────────
GARMIN_USERNAME=
GARMIN_PASSWORD=

# ── Anthropic (only needed when USE_API=true) ──────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── AI mode ────────────────────────────────────────────────────────────────────
# false = POC: uses `claude --print` (Claude Code CLI must be installed)
# true  = production: uses Anthropic API (Docker always sets this to true)
USE_API=false
